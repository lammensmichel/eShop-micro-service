@page
@model Identity.API.Pages.Account.Login.LoginModel
<!DOCTYPE html>
<html>
<head>
    <title>eShop — Connexion</title>
    <style>
        body { font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; background: #f0f4ff; }
        .login-box { background: white; padding: 2rem; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.1); width: 320px; }
        h1 { margin-bottom: 1.5rem; color: #1a1a2e; }
        input[type=text], input[type=password] { width: 100%; padding: 0.6rem; margin: 0.4rem 0 1rem; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box; }
        button { width: 100%; padding: 0.75rem; background: #0d6efd; color: white; border: none; border-radius: 6px; cursor: pointer; font-size: 1rem; }
        .error { color: red; margin-bottom: 1rem; }
    </style>
</head>
<body>
    <div class="login-box">
        <h1>🛍️ eShop</h1>
        <h2>Connexion</h2>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <p class="error">@Model.ErrorMessage</p>
        }
        <form method="post">
            @Html.AntiForgeryToken()
            <input type="text" name="Username" placeholder="Nom d'utilisateur" autocomplete="username" />
            <input type="password" name="Password" placeholder="Mot de passe" autocomplete="current-password" />
            <input type="hidden" name="returnUrl" value="@Model.ReturnUrl" />
            <button type="submit">Se connecter</button>
        </form>
        <p style="margin-top:1rem; font-size:0.85rem; color:#666">
            alice ou bob / Pass123$
        </p>
    </div>
</body>
</html>
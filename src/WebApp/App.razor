@* Composant racine de l'application.
   - CascadingAuthenticationState diffuse l'état d'authentification (utilisateur connecté
     ou non) à TOUS les composants descendants, ce qui fait fonctionner <AuthorizeView>,
     [Authorize] et @context.User partout dans l'app.
   - Router fait correspondre l'URL courante à une page (@page) trouvée dans cet assembly.
   - AuthorizeRouteView combine routage ET autorisation : si la page exige l'auth via
     [Authorize] et que l'utilisateur n'est pas connecté, le bloc <NotAuthorized> s'affiche
     à la place de la page. *@
<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(Layout.MainLayout)">
                <NotAuthorized>
                    <p>Vous devez être connecté. <a href="authentication/login">Se connecter</a></p>
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <LayoutView Layout="@typeof(Layout.MainLayout)">
                <p>Page introuvable. <a href="/">Retour à l'accueil</a></p>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
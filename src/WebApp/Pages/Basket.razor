@page "/basket"

@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject BuyerIdProvider BuyerIdProvider

<h1>🛒 Mon Panier</h1>

@if (_error is not null)
{
    <p style="color:red">Erreur : @_error</p>
}
else if (_basket is null)
{
    <p>Chargement...</p>
}
else if (_basket.Items.Count == 0)
{
    <p>Votre panier est vide. <a href="/catalog">Voir le catalogue</a></p>
}
else
{
    <table class="basket-table">
        <thead>
            <tr>
                <th>Produit</th>
                <th>Prix unitaire</th>
                <th>Quantité</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _basket.Items)
            {
                <tr>
                    <td>@item.ProductName</td>
                    <td>@item.UnitPrice.ToString("C")</td>
                    <td>@item.Quantity</td>
                    <td>@item.TotalPrice.ToString("C")</td>
                </tr>
            }
        </tbody>
    </table>

    <p><strong>Total : @_basket.TotalPrice.ToString("C")</strong></p>
    <button class="checkout-btn" @onclick="Checkout">✅ Passer commande</button>
}

@if (_message is not null)
{
    <p class="success-msg">@_message</p>
}

@code {
    private BasketDto? _basket;
    private string? _message;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var buyerId = await BuyerIdProvider.GetBuyerIdAsync();
            var client = HttpClientFactory.CreateClient("BasketAPI");
            _basket = await client.GetFromJsonAsync<BasketDto>($"/api/basket/{buyerId}");
        }
        catch (AccessTokenNotAvailableException ex)
        {
            // Jeton expiré : on redirige vers la connexion.
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    private async Task Checkout()
    {
        try
        {
            var buyerId = await BuyerIdProvider.GetBuyerIdAsync();
            var client = HttpClientFactory.CreateClient("BasketAPI");
            var response = await client.PostAsJsonAsync("/api/basket/checkout", new
            {
                buyerId,
                city = "Brussels",
                street = "Rue de la Loi 1",
                country = "Belgium",
                zipCode = "1000",
                cardNumber = "4111111111111111",
                cardHolderName = "User",
                cardExpiration = "2027-01-01"
            });
            response.EnsureSuccessStatusCode();
            _message = "🎉 Commande passée avec succès !";
            _basket = new BasketDto { BuyerId = buyerId };
        }
        catch (AccessTokenNotAvailableException ex)
        {
            // Jeton expiré : on redirige vers la connexion.
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
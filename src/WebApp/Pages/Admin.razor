@* Page Administration : gestion du catalogue (ajout/suppression de produits).
   [Authorize(Roles = "Admin")] restreint l'accès aux utilisateurs ayant le rôle "Admin"
   (ex. alice). Ce contrôle côté front N'EST PAS suffisant : Catalog.API revérifie le rôle
   côté serveur sur POST/DELETE (défense en profondeur). Ici, le rôle ne fonctionne que
   parce que RolesClaimsPrincipalFactory a éclaté le claim "role" en claims individuels. *@
@page "/admin"
@attribute [Authorize(Roles = "Admin")]
@inject IHttpClientFactory HttpClientFactory

<div class="page-header">
    <h1>⚙️ Administration</h1>
</div>

@if (_message is not null)
{
    <div class="alert @(_message.StartsWith("❌") ? "alert-danger" : "alert-success")">@_message</div>
}

<div class="card" style="margin-bottom: 2rem; max-width: 520px;">
    <h2>Ajouter un produit</h2>

    <div class="form-group">
        <label class="form-label">Nom du produit</label>
        <input class="form-input" @bind="_name" placeholder="Ex. T-shirt eShop" />
    </div>
    <div class="form-group">
        <label class="form-label">Description</label>
        <input class="form-input" @bind="_description" placeholder="Courte description du produit" />
    </div>
    <div class="form-group">
        <label class="form-label">Prix (€)</label>
        <input class="form-input" @bind="_price" type="number" placeholder="0.00" />
    </div>
    <div class="form-group">
        <label class="form-label">Stock</label>
        <input class="form-input" @bind="_stock" type="number" placeholder="0" />
    </div>
    <div class="form-group">
        <label class="form-label">Marque</label>
        <select class="form-select" @bind="_brandId">
            @foreach (var brand in _brands)
            {
                <option value="@brand.Id">@brand.Name</option>
            }
        </select>
    </div>
    <div class="form-group">
        <label class="form-label">Type</label>
        <select class="form-select" @bind="_typeId">
            @foreach (var type in _types)
            {
                <option value="@type.Id">@type.Type</option>
            }
        </select>
    </div>

    <button class="btn btn-primary btn-block" @onclick="AddProduct">
        ➕ Ajouter le produit
    </button>
</div>

<h2>Produits existants</h2>

@if (_items is not null)
{
    <table class="table">
        <thead>
            <tr>
                <th>Nom</th>
                <th class="text-right">Prix</th>
                <th class="text-right">Stock</th>
                <th class="text-right">Action</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in _items)
            {
                <tr>
                    <td>@item.Name</td>
                    <td class="text-right">@item.Price.ToString("C")</td>
                    <td class="text-right">@item.AvailableStock</td>
                    <td class="text-right">
                        <button class="btn btn-danger btn-sm" @onclick="() => DeleteProduct(item.Id)">
                            🗑️ Supprimer
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    // État du formulaire et des listes affichées. Les champs _name/_price/... sont liés
    // aux <input> du markup via @bind (liaison bidirectionnelle Blazor).
    private List<CatalogItemDto>? _items;
    private List<BrandDto> _brands = []; // alimente la liste déroulante des marques
    private List<TypeDto> _types = [];   // alimente la liste déroulante des types
    private string _name = string.Empty;
    private string _description = string.Empty;
    private decimal _price;
    private int _stock;
    private int _brandId;
    private int _typeId;
    private string? _message;

    // Au montage : charge les produits existants ainsi que les marques/types disponibles
    // pour pré-remplir les listes déroulantes du formulaire d'ajout.
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("CatalogAPI");
            _items = await client.GetFromJsonAsync<List<CatalogItemDto>>("/api/catalog/items");
            _brands = await client.GetFromJsonAsync<List<BrandDto>>("/api/catalog/brands") ?? [];
            _types = await client.GetFromJsonAsync<List<TypeDto>>("/api/catalog/types") ?? [];
            // Sélectionne par défaut la première marque/le premier type s'ils existent.
            if (_brands.Any()) _brandId = _brands[0].Id;
            if (_types.Any()) _typeId = _types[0].Id;
        }
        catch (AccessTokenNotAvailableException ex)
        {
            // Jeton expiré : on redirige vers la connexion.
            ex.Redirect();
        }
        catch (Exception ex)
        {
            // Gestion d'erreur générique : toute autre défaillance (réseau, HTTP 500,
            // timeout, désérialisation...) est capturée ici pour éviter que le handler
            // Blazor ne plante et n'affiche le bandeau générique sans contexte.
            // On renseigne _message (déjà affiché par le markup) avec un message lisible.
            // _items reste null : la table ne s'affiche pas, l'utilisateur voit l'erreur.
            _message = $"❌ Impossible de charger le catalogue : {ex.Message}";
        }
    }

    // Crée un produit via POST /api/catalog/items (endpoint protégé "Admin" côté serveur),
    // puis recharge la liste pour refléter l'ajout.
    private async Task AddProduct()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("CatalogAPI");
            var newItem = new
            {
                name = _name,
                description = _description,
                price = _price,
                pictureFileName = "default.png",
                availableStock = _stock,
                catalogBrandId = _brandId,
                catalogTypeId = _typeId
            };
            // On vérifie le code HTTP : en cas d'échec, on n'affiche pas un faux succès
            // et on ne recharge pas inutilement la liste.
            var resp = await client.PostAsJsonAsync("/api/catalog/items", newItem);
            if (resp.IsSuccessStatusCode)
            {
                // Recharge la liste depuis le serveur pour refléter l'ajout réel.
                _items = await client.GetFromJsonAsync<List<CatalogItemDto>>("/api/catalog/items");
                _message = $"✅ {_name} ajouté !";
                _name = string.Empty;
                _description = string.Empty;
            }
            else
            {
                _message = $"❌ Échec de l'ajout (HTTP {(int)resp.StatusCode})";
            }
        }
        catch (AccessTokenNotAvailableException ex)
        {
            // Jeton expiré : on redirige vers la connexion.
            ex.Redirect();
        }
        catch (Exception ex)
        {
            // Gestion d'erreur générique : capture toute défaillance (réseau, HTTP 500,
            // timeout, désérialisation...) pour ne pas faire planter le composant.
            // On affiche un message d'erreur lisible via _message.
            _message = $"❌ Échec de l'ajout du produit : {ex.Message}";
        }
    }

    // Supprime un produit côté serveur. On ne met à jour l'affichage QUE si le serveur
    // confirme la suppression (code HTTP de succès), pour éviter de masquer un produit
    // qui n'a en réalité pas été supprimé (échec d'autorisation, erreur serveur...).
    private async Task DeleteProduct(int id)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("CatalogAPI");
            var resp = await client.DeleteAsync($"/api/catalog/items/{id}");
            if (resp.IsSuccessStatusCode)
            {
                // Recharge la liste depuis le serveur (source de vérité).
                _items = await client.GetFromJsonAsync<List<CatalogItemDto>>("/api/catalog/items");
                _message = "✅ Produit supprimé !";
            }
            else
            {
                _message = $"❌ Échec de la suppression (HTTP {(int)resp.StatusCode})";
            }
        }
        catch (AccessTokenNotAvailableException ex)
        {
            // Jeton expiré : on redirige vers la connexion.
            ex.Redirect();
        }
        catch (Exception ex)
        {
            // Gestion d'erreur générique : capture toute défaillance (réseau, HTTP 500,
            // timeout, désérialisation...) pour ne pas faire planter le composant.
            // On affiche un message d'erreur lisible via _message.
            _message = $"❌ Échec de la suppression du produit : {ex.Message}";
        }
    }
}

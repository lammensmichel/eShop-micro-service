@page "/orders"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject BuyerIdProvider BuyerIdProvider

<h1>📋 Mes Commandes</h1>

@if (_error is not null)
{
    <p style="color:red">Erreur : @_error</p>
}
else if (_orders is null)
{
    <p>Chargement...</p>
}
else if (_orders.Count == 0)
{
    <p>Aucune commande. <a href="/catalog">Faire des achats</a></p>
}
else
{
    @foreach (var order in _orders)
    {
        <div class="order-card">
            <p><strong>Commande #@order.Id</strong> <span class="status">@order.Status</span></p>
            <p>Date : @order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
            <p>Total : <strong>@order.Total.ToString("C")</strong></p>
            <ul>
                @foreach (var item in order.Items)
                {
                    <li>@item.ProductName × @item.Units — @item.UnitPrice.ToString("C")</li>
                }
            </ul>
        </div>
    }
}

@code {
    private List<OrderDto>? _orders;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var buyerId = await BuyerIdProvider.GetBuyerIdAsync();
            var client = HttpClientFactory.CreateClient("OrderingAPI");
            _orders = await client.GetFromJsonAsync<List<OrderDto>>($"/api/orders/{buyerId}");
        }
        catch (AccessTokenNotAvailableException ex)
        {
            // Jeton expiré : on redirige vers la connexion.
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }
}
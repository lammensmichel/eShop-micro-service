@* Page Commandes : dernière étape du parcours.
   Affiche l'historique des commandes de l'utilisateur, lu depuis Ordering.API.
   Comme le checkout est asynchrone (via RabbitMQ), une commande tout juste passée peut
   apparaître ici avec un court délai. [Authorize] impose d'être connecté. *@
@page "/orders"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject BuyerIdProvider BuyerIdProvider

<div class="page-header" style="display:flex; align-items:center; justify-content:space-between; gap:1rem;">
    <h1>📋 Mes Commandes</h1>
    <button class="btn btn-outline btn-sm" @onclick="RefreshAsync" disabled="@_loading">
        @(_loading ? "⏳ Chargement…" : "🔄 Rafraîchir")
    </button>
</div>

@* Le checkout est asynchrone (panier → événement RabbitMQ → création de la commande).
   Une commande tout juste passée apparaît donc avec un léger délai : la page se
   rafraîchit automatiquement quelques secondes après l'ouverture, et le bouton
   ci-dessus permet de relancer la lecture à tout moment. *@
@if (_orders is { Count: 0 } && _autoRefreshing)
{
    <div class="alert alert-info">⏳ Votre commande vient peut-être d'être validée — actualisation en cours…</div>
}

@if (_error is not null)
{
    <div class="alert alert-danger">Erreur : @_error</div>
}
else if (_orders is null)
{
    <div class="loading"><span class="spinner"></span> Chargement des commandes...</div>
}
else if (_orders.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📋</div>
        <h3>Aucune commande</h3>
        <p>Vous n'avez pas encore passé de commande.</p>
        <a href="/catalog" class="btn btn-primary">📦 Faire des achats</a>
    </div>
}
else
{
    @foreach (var order in _orders)
    {
        <div class="order-card">
            <div class="order-head">
                <div>
                    <span class="order-id">Commande #@order.Id</span>
                    <div class="order-date">@order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <span class="badge @StatusBadgeClass(order.Status)">@StatusLabel(order.Status)</span>
            </div>
            <ul class="order-items">
                @foreach (var item in order.Items)
                {
                    <li>
                        <span class="item-name">@item.ProductName</span>
                        <span class="item-qty">@item.Units × @item.UnitPrice.ToString("C")</span>
                    </li>
                }
            </ul>
            <div class="order-footer">
                Total : <strong>@order.Total.ToString("C")</strong>
            </div>
        </div>
    }
}

@code {
    private List<OrderDto>? _orders; // null = chargement ; vide = aucune commande
    private string? _error;
    private bool _loading;        // un appel de lecture est en cours (désactive le bouton)
    private bool _autoRefreshing; // un cycle d'auto-rafraîchissement est en cours

    // Au chargement : on lit les commandes, puis on lance un petit cycle d'auto-
    // rafraîchissement. Pourquoi ? Le checkout est ASYNCHRONE : valider le panier publie
    // un événement RabbitMQ, et la commande n'est créée que lorsque Ordering.API l'a
    // consommé (un court instant plus tard). Sans cela, l'utilisateur qui arrive ici juste
    // après le checkout verrait « Aucune commande » à tort.
    protected override async Task OnInitializedAsync()
    {
        await LoadOrdersAsync();
        await AutoRefreshUntilOrdersAppearAsync();
    }

    // Lecture des commandes de l'utilisateur courant (filtrées par BuyerId côté API).
    private async Task LoadOrdersAsync()
    {
        _loading = true;
        _error = null;
        try
        {
            var buyerId = await BuyerIdProvider.GetBuyerIdAsync();
            var client = HttpClientFactory.CreateClient("OrderingAPI");
            _orders = await client.GetFromJsonAsync<List<OrderDto>>($"/api/orders/{buyerId}");
        }
        catch (AccessTokenNotAvailableException ex)
        {
            // Jeton expiré : on redirige vers la connexion.
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    // Bouton « Rafraîchir » : relit la liste à la demande.
    private Task RefreshAsync() => LoadOrdersAsync();

    // Rattrape une commande créée de façon asynchrone : tant que la liste est vide, on
    // relit quelques fois à intervalle court, puis on s'arrête (pour ne pas interroger
    // l'API indéfiniment). Un vrai « temps réel » utiliserait plutôt SignalR/WebSocket.
    private async Task AutoRefreshUntilOrdersAppearAsync()
    {
        _autoRefreshing = true;
        for (var attempt = 0; attempt < 5 && _orders is { Count: 0 } && _error is null; attempt++)
        {
            await Task.Delay(2500);
            await LoadOrdersAsync();
            StateHasChanged();
        }
        _autoRefreshing = false;
    }

    // Associe chaque statut de commande (renvoyé en minuscules par Ordering.API) à
    // une variante de badge colorée. Purement cosmétique (affichage).
    private static string StatusBadgeClass(string status) => status?.ToLowerInvariant() switch
    {
        "submitted"          => "badge-neutral",
        "awaitingvalidation" => "badge-warning",
        "stockconfirmed"     => "badge-info",
        "paid"               => "badge-teal",
        "shipped"            => "badge-success",
        "cancelled"          => "badge-danger",
        _                    => "badge-neutral"
    };

    // Libellé français lisible pour chaque statut (l'affichage seulement).
    private static string StatusLabel(string status) => status?.ToLowerInvariant() switch
    {
        "submitted"          => "Soumise",
        "awaitingvalidation" => "En attente de validation",
        "stockconfirmed"     => "Stock confirmé",
        "paid"               => "Payée",
        "shipped"            => "Expédiée",
        "cancelled"          => "Annulée",
        _                    => status ?? "Inconnu"
    };
}
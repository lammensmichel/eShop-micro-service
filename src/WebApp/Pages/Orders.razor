@* Page Commandes : dernière étape du parcours.
   Affiche l'historique des commandes de l'utilisateur, lu depuis Ordering.API.
   Comme le checkout est asynchrone (via RabbitMQ), une commande tout juste passée peut
   apparaître ici avec un court délai. [Authorize] impose d'être connecté. *@
@page "/orders"
@attribute [Authorize]
@inject IHttpClientFactory HttpClientFactory
@inject BuyerIdProvider BuyerIdProvider

<div class="page-header">
    <h1>📋 Mes Commandes</h1>
</div>

@if (_error is not null)
{
    <div class="alert alert-danger">Erreur : @_error</div>
}
else if (_orders is null)
{
    <div class="loading"><span class="spinner"></span> Chargement des commandes...</div>
}
else if (_orders.Count == 0)
{
    <div class="empty-state">
        <div class="empty-icon">📋</div>
        <h3>Aucune commande</h3>
        <p>Vous n'avez pas encore passé de commande.</p>
        <a href="/catalog" class="btn btn-primary">📦 Faire des achats</a>
    </div>
}
else
{
    @foreach (var order in _orders)
    {
        <div class="order-card">
            <div class="order-head">
                <div>
                    <span class="order-id">Commande #@order.Id</span>
                    <div class="order-date">@order.OrderDate.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</div>
                </div>
                <span class="badge @StatusBadgeClass(order.Status)">@StatusLabel(order.Status)</span>
            </div>
            <ul class="order-items">
                @foreach (var item in order.Items)
                {
                    <li>
                        <span class="item-name">@item.ProductName</span>
                        <span class="item-qty">@item.Units × @item.UnitPrice.ToString("C")</span>
                    </li>
                }
            </ul>
            <div class="order-footer">
                Total : <strong>@order.Total.ToString("C")</strong>
            </div>
        </div>
    }
}

@code {
    private List<OrderDto>? _orders; // null = chargement ; vide = aucune commande
    private string? _error;

    // Charge les commandes de l'utilisateur courant (filtrées par BuyerId côté API).
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var buyerId = await BuyerIdProvider.GetBuyerIdAsync();
            var client = HttpClientFactory.CreateClient("OrderingAPI");
            _orders = await client.GetFromJsonAsync<List<OrderDto>>($"/api/orders/{buyerId}");
        }
        catch (AccessTokenNotAvailableException ex)
        {
            // Jeton expiré : on redirige vers la connexion.
            ex.Redirect();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
    }

    // Associe chaque statut de commande (renvoyé en minuscules par Ordering.API) à
    // une variante de badge colorée. Purement cosmétique (affichage).
    private static string StatusBadgeClass(string status) => status?.ToLowerInvariant() switch
    {
        "submitted"          => "badge-neutral",
        "awaitingvalidation" => "badge-warning",
        "stockconfirmed"     => "badge-info",
        "paid"               => "badge-teal",
        "shipped"            => "badge-success",
        "cancelled"          => "badge-danger",
        _                    => "badge-neutral"
    };

    // Libellé français lisible pour chaque statut (l'affichage seulement).
    private static string StatusLabel(string status) => status?.ToLowerInvariant() switch
    {
        "submitted"          => "Soumise",
        "awaitingvalidation" => "En attente de validation",
        "stockconfirmed"     => "Stock confirmé",
        "paid"               => "Payée",
        "shipped"            => "Expédiée",
        "cancelled"          => "Annulée",
        _                    => status ?? "Inconnu"
    };
}
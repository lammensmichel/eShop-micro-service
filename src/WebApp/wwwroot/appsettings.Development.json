{
  // =============================================================================
  // Configuration de DÉVELOPPEMENT du client Blazor WASM.
  //
  // POURQUOI ce fichier ?
  //   Blazor WASM charge appsettings.json PUIS appsettings.{Environment}.json. En dev,
  //   l'environnement est "Development", donc ce fichier est chargé EN DERNIER et ses
  //   valeurs ÉCRASENT les placeholders "REPLACE_..." de appsettings.json. Résultat :
  //   en local, Program.cs lit directement ces URLs localhost et le dev fonctionne tel
  //   quel, sans déploiement ni templatisation.
  //
  // Ces URLs correspondent aux endpoints HTTPS exposés par Aspire en local
  //   (mêmes ports que les anciens fallback codés en dur) :
  //     catalog 7117 / basket 7225 / ordering 7102 / identity 7267.
  //
  // Placé sous wwwroot/, ce fichier est copié tel quel dans la sortie de build (tout
  //   wwwroot l'est par défaut) et servi en statique au navigateur. Aucun secret ici.
  // =============================================================================
  "Backend": {
    "CatalogApi": "https://localhost:7117",
    "BasketApi": "https://localhost:7225",
    "OrderingApi": "https://localhost:7102",
    "IdentityAuthority": "https://localhost:7267"
  }
}

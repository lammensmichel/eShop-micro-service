{
  // =============================================================================
  // Configuration PUBLIQUE du client Blazor WebAssembly (chargée DANS le navigateur).
  //
  // POURQUOI ce fichier ?
  //   Blazor WASM charge automatiquement wwwroot/appsettings.json dans IConfiguration
  //   au démarrage (puis wwwroot/appsettings.{Environment}.json par-dessus). C'est le
  //   SEUL canal de configuration qui atteint réellement le bundle WASM exécuté chez
  //   l'utilisateur. Les clés de service discovery d'Aspire ("services:...") ne sont
  //   injectées que dans le PROCESS WebApp.Server, jamais dans le navigateur : elles
  //   ne pouvaient donc pas servir en production.
  //
  // CONTENU : les URLs PUBLIQUES des backends, sous forme de PLACEHOLDERS "REPLACE_...".
  //   Au déploiement, on templatise ce fichier (remplacement des REPLACE_... par les
  //   vraies URLs publiques). Program.cs échoue volontairement au démarrage si un
  //   placeholder subsiste (fail fast = on détecte tout de suite une prod mal configurée).
  //
  // IMPORTANT : ce fichier est PUBLIC (téléchargé par le navigateur). N'y mettre AUCUN
  //   secret — uniquement des URLs publiques.
  //
  // DEV LOCAL : en environnement Development, appsettings.Development.json écrase ces
  //   placeholders par les URLs localhost (voir ce fichier voisin). Le dev reste donc
  //   pleinement fonctionnel sans toucher à ce fichier-ci.
  // =============================================================================
  "Backend": {
    "CatalogApi": "https://REPLACE_CATALOG_URL",
    "BasketApi": "https://REPLACE_BASKET_URL",
    "OrderingApi": "https://REPLACE_ORDERING_URL",
    "IdentityAuthority": "https://REPLACE_IDENTITY_URL"
  }
}

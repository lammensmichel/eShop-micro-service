@* Gabarit principal partagé par toutes les pages (menu latéral + barre du haut + contenu).
   La barre du haut utilise <AuthorizeView> pour afficher soit le nom de l'utilisateur
   connecté + un bouton de déconnexion, soit un lien "Se connecter". @Body est l'emplacement
   où la page courante (routée par App.razor) est injectée. *@
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>
    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    👤 @context.User.Identity?.Name
                    <button @onclick="BeginLogout" style="background:none; border:none; color:#0d6efd; cursor:pointer; text-decoration:underline; margin-left:1rem;">
                        🚪 Déconnexion
                    </button>
                </Authorized>
                <NotAuthorized>
                    <a href="authentication/login">🔑 Se connecter</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    [Inject] NavigationManager Navigation { get; set; } = default!;

    // Lance la déconnexion OIDC : redirige vers la page "authentication/logout",
    // qui (via RemoteAuthenticatorView) révoque la session locale et le jeton.
    private void BeginLogout()
    {
        Navigation.NavigateToLogout("authentication/logout");
    }
}
@* Gabarit principal partagé par toutes les pages (menu latéral + barre du haut + contenu).
   La barre du haut utilise <AuthorizeView> pour afficher soit le nom de l'utilisateur
   connecté + un bouton de déconnexion, soit un lien "Se connecter". @Body est l'emplacement
   où la page courante (routée par App.razor) est injectée. *@
@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication

<div class="app-shell">
    @* En-tête sticky : marque eShop + navigation + zone utilisateur. *@
    <header class="app-header">
        <div class="app-header-inner">
            <a class="brand" href="">
                <span class="brand-mark">🛍️</span>
                <span class="brand-name">eShop</span>
            </a>

            <NavMenu />

            <div class="user-zone">
                <AuthorizeView>
                    <Authorized>
                        <span class="user-name">👤 @context.User.Identity?.Name</span>
                        <button class="btn btn-outline btn-sm" @onclick="BeginLogout">
                            🚪 Déconnexion
                        </button>
                    </Authorized>
                    <NotAuthorized>
                        <a class="btn btn-primary btn-sm" href="authentication/login">🔑 Se connecter</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <main class="app-main">
        <div class="page-container">
            @Body
        </div>
    </main>

    <footer class="app-footer">
        <div class="page-container">
            eShop — boutique de démonstration .NET 10 · Blazor WebAssembly
        </div>
    </footer>
</div>

@code {
    [Inject] NavigationManager Navigation { get; set; } = default!;

    // Lance la déconnexion OIDC : redirige vers la page "authentication/logout",
    // qui (via RemoteAuthenticatorView) révoque la session locale et le jeton.
    private void BeginLogout()
    {
        Navigation.NavigateToLogout("authentication/logout");
    }
}